{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CT/CE Learn task bank — v10.21",
  "description": "Schema enforced on every task in every Learn bank. The generator emits objects matching this shape; audit.mjs validates them.",
  "type": "object",
  "required": ["id", "name", "canonicalSubId", "canonicalTopicId", "tasks"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 4 },
    "canonicalSubId": { "type": "string", "pattern": "^cs-[a-z0-9-]+$" },
    "canonicalTopicId": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "stem", "options", "answer", "explanation", "fullExplanation", "source", "flavor"],
        "properties": {
          "id":            { "type": "string", "pattern": "^[a-z][a-z0-9-]+-\\d{2}$" },
          "stem":          { "type": "string", "minLength": 30, "maxLength": 400 },
          "options":       {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": { "type": "string", "minLength": 1 }
          },
          "answer":        { "type": "string", "minLength": 1 },
          "explanation":   { "type": "string", "minLength": 20, "maxLength": 220 },
          "fullExplanation":{ "type": "string", "minLength": 60, "maxLength": 500 },
          "source":        { "type": "string", "minLength": 4 },
          "flavor":        { "type": "string", "enum": ["personalities","history","social","science","quotes"] },
          "author":        { "type": "string" },
          "hint":          { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
